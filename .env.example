# Datenbank (PostgreSQL)
DATABASE_URL="postgresql://sdboard:DEIN_PASSWORT@localhost:5432/sdboard"

# NextAuth
NEXTAUTH_URL="https://board.sdbrowser.de"
NEXTAUTH_SECRET="ZUFAELLIGER_LANGER_STRING_HIER"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord OAuth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Coolify / Production (optional)
# Setze RUN_SEED nur bewusst auf true, wenn Demo-Daten angelegt werden sollen.
RUN_SEED="false"
SKIP_DB_PUSH="false"
DB_PUSH_MAX_ATTEMPTS="30"
DB_PUSH_RETRY_SECONDS="2"

# Nur noetig, wenn Server Actions hinter einem Proxy mit abweichendem Origin laufen.
# Kommagetrennte Hostnamen ohne Protokoll, z.B. "board.example.de,*.example.de"
SERVER_ACTION_ALLOWED_ORIGINS=""

# Optional fuer Rolling Deployments / Version-Skew-Schutz.
DEPLOYMENT_VERSION=""
